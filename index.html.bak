<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OpenClaw Courses | Master AI Agents</title>
    <meta
      name="description"
      content="Master AI agents with OpenClaw courses. Self-paced training, team workshops, and early access pricing."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Sora:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Space Grotesk', 'ui-sans-serif', 'system-ui'],
              display: ['Sora', 'Space Grotesk', 'ui-sans-serif'],
            },
            colors: {
              ink: '#060714',
              panel: '#0c1024',
              line: '#1f2a59',
              neon: '#6ea8ff',
              violet: '#9f7cff',
            },
            boxShadow: {
              glow: '0 10px 40px rgba(99, 102, 241, 0.25)',
            },
            keyframes: {
              rise: {
                '0%': { opacity: '0', transform: 'translateY(16px)' },
                '100%': { opacity: '1', transform: 'translateY(0)' },
              },
            },
            animation: {
              rise: 'rise 550ms ease-out both',
            },
          },
        },
      };
    </script>
    <style>
      :root {
        color-scheme: dark;
      }
      body {
        background:
          radial-gradient(1200px 600px at 10% 0%, rgba(99, 102, 241, 0.22), transparent 60%),
          radial-gradient(900px 500px at 90% 10%, rgba(59, 130, 246, 0.2), transparent 60%),
          #060714;
      }
      .card-border {
        background: linear-gradient(140deg, rgba(159, 124, 255, 0.35), rgba(110, 168, 255, 0.12));
        padding: 1px;
      }
    </style>
  </head>
  <body class="text-slate-100 antialiased">
    <header class="sticky top-0 z-20 border-b border-line/70 bg-ink/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
        <p class="font-display text-sm tracking-[0.22em] text-slate-300">LEARN-OPENCLAW.COM</p>
        <a
          href="#pricing"
          class="rounded-full bg-gradient-to-r from-violet to-neon px-4 py-2 text-sm font-semibold text-white transition hover:scale-[1.02]"
          >Enroll Now</a
        >
      </div>
    </header>

    <main>
      <section class="mx-auto max-w-6xl px-4 pb-14 pt-14 sm:px-6 lg:px-8 lg:pt-20">
        <div class="card-border animate-rise rounded-3xl shadow-glow">
          <div class="rounded-3xl bg-panel/95 p-8 sm:p-12">
            <p class="mb-4 inline-flex rounded-full border border-violet/40 bg-violet/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-violet-200">
              Early Access: 40% Off Through Feb 28, 2026
            </p>
            <h1 class="font-display text-4xl leading-tight sm:text-5xl lg:text-6xl">
              Master AI Agents. <span class="bg-gradient-to-r from-violet-300 to-blue-300 bg-clip-text text-transparent">Transform Your Business.</span>
            </h1>
            <p class="mt-5 max-w-2xl text-lg text-slate-300">
              Learn to build, deploy, and scale AI agents with OpenClaw. From zero to automation hero in weeks, not months.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="#pricing"
                class="rounded-xl bg-gradient-to-r from-violet to-neon px-6 py-3 text-center font-semibold text-white transition hover:brightness-110"
                >Enroll Now → Starting at $497</a
              >
              <a
                href="#faq"
                class="rounded-xl border border-line px-6 py-3 text-center font-semibold text-slate-200 transition hover:border-neon/60 hover:text-white"
                >View FAQ</a
              >
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-6xl px-4 pb-14 sm:px-6 lg:px-8">
        <div class="grid gap-4 rounded-2xl border border-line bg-panel/70 p-6 sm:grid-cols-2 lg:grid-cols-4">
          <p class="text-sm text-slate-300">YouTube tutorials are outdated by next week</p>
          <p class="text-sm text-slate-300">Docs assume you're already an engineer</p>
          <p class="text-sm text-slate-300">Prompts don't feel like real automation</p>
          <p class="text-sm text-slate-300">The gap isn't intelligence. It's practical knowledge.</p>
        </div>
      </section>

      <section id="pricing" class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
        <div class="mb-8 flex items-end justify-between gap-4">
          <div>
            <h2 class="font-display text-3xl sm:text-4xl">Self-Paced Courses</h2>
            <p class="mt-2 text-slate-300">Pick one track or bundle all three for complete mastery.</p>
          </div>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          <article class="card-border rounded-2xl">
            <div class="flex h-full flex-col rounded-2xl bg-panel p-6">
              <p class="text-sm text-violet-200">OpenClaw Fundamentals</p>
              <p class="mt-2 text-4xl font-bold">$497</p>
              <p class="mt-2 text-sm text-slate-300">6 hours · Lifetime access · No coding required</p>
              <ul class="mt-5 space-y-2 text-sm text-slate-200">
                <li>Build your first agent from scratch</li>
                <li>Connect Gmail, Calendar, Slack, and more</li>
                <li>6 hours of videos + project files</li>
                <li>Private community + 30-day support</li>
              </ul>
              <a href="#" class="mt-6 rounded-lg border border-line px-4 py-2 text-center text-sm font-semibold transition hover:border-neon/70">Choose Fundamentals</a>
            </div>
          </article>

          <article class="card-border rounded-2xl">
            <div class="flex h-full flex-col rounded-2xl bg-panel p-6">
              <p class="text-sm text-violet-200">Advanced Agent Engineering</p>
              <p class="mt-2 text-4xl font-bold">$997</p>
              <p class="mt-2 text-sm text-slate-300">12 hours · Lifetime access · Build multi-agent systems</p>
              <ul class="mt-5 space-y-2 text-sm text-slate-200">
                <li>Orchestration, custom tools, and memory systems</li>
                <li>Production deployment and safety patterns</li>
                <li>5 project templates + code repository</li>
                <li>Private Discord + 60-day support</li>
              </ul>
              <a href="#" class="mt-6 rounded-lg border border-line px-4 py-2 text-center text-sm font-semibold transition hover:border-neon/70">Choose Advanced</a>
            </div>
          </article>

          <article class="card-border rounded-2xl">
            <div class="flex h-full flex-col rounded-2xl bg-panel p-6">
              <p class="text-sm text-violet-200">AI Agent Business Accelerator</p>
              <p class="mt-2 text-4xl font-bold">$2,497</p>
              <p class="mt-2 text-sm text-slate-300">20 hours · Lifetime access · Turn skills into revenue</p>
              <ul class="mt-5 space-y-2 text-sm text-slate-200">
                <li>Agency model, productization, and pricing</li>
                <li>Proposal and contract templates</li>
                <li>Private mastermind + 2 group coaching calls</li>
                <li>90-day email support</li>
              </ul>
              <a href="#" class="mt-6 rounded-lg border border-line px-4 py-2 text-center text-sm font-semibold transition hover:border-neon/70">Choose Accelerator</a>
            </div>
          </article>
        </div>
      </section>

      <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
        <div class="grid gap-6 lg:grid-cols-5">
          <article class="card-border rounded-2xl lg:col-span-3">
            <div class="h-full rounded-2xl bg-panel p-7">
              <p class="text-xs uppercase tracking-[0.2em] text-blue-200">Group Training</p>
              <h3 class="mt-3 font-display text-2xl">Team Transformation Workshop</h3>
              <p class="mt-2 text-4xl font-bold">$4,997 <span class="text-base font-medium text-slate-300">2-day virtual intensive</span></p>
              <p class="mt-4 text-slate-300">Train your team on AI agents with your real workflows and data.</p>
              <ul class="mt-4 grid gap-2 text-sm text-slate-200 sm:grid-cols-2">
                <li>Pre-workshop assessment</li>
                <li>2 full days of live training</li>
                <li>Custom automation roadmap</li>
                <li>30 days follow-up support</li>
                <li>Virtual or on-site delivery</li>
                <li>Fundamentals included for all participants</li>
              </ul>
            </div>
          </article>

          <article class="card-border rounded-2xl lg:col-span-2">
            <div class="flex h-full flex-col justify-between rounded-2xl bg-gradient-to-br from-violet-950/80 via-panel to-blue-950/70 p-7">
              <div>
                <p class="text-xs uppercase tracking-[0.2em] text-violet-200">Bundle Deal</p>
                <h3 class="mt-3 font-display text-2xl">All Courses Bundle</h3>
                <p class="mt-2 text-sm text-slate-300">Fundamentals + Advanced + Accelerator</p>
                <p class="mt-5 text-4xl font-bold">$2,997</p>
                <p class="mt-1 text-slate-300"><span class="line-through">$4,491</span> · Save 33%</p>
              </div>
              <a href="#" class="mt-6 rounded-lg bg-white/10 px-4 py-3 text-center font-semibold text-white transition hover:bg-white/20">Claim Bundle</a>
            </div>
          </article>
        </div>
      </section>

      <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-violet/40 bg-gradient-to-r from-violet-900/40 via-indigo-900/30 to-blue-900/40 p-7 sm:p-10">
          <p class="text-xs uppercase tracking-[0.22em] text-violet-200">Limited Time Offer</p>
          <h2 class="mt-3 font-display text-3xl sm:text-4xl">Early Access Pricing: 40% Off</h2>
          <p class="mt-3 max-w-3xl text-slate-200">
            Launching in Q1 2026. Early enrollees get founding member community access, direct feedback lines to instructors, and first influence on future modules.
          </p>
          <p class="mt-4 text-sm font-semibold text-blue-200">Pricing goes up after February 28, 2026.</p>
          <!-- Email Capture Form -->
          <form id="waitlist-form" class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <input type="text" name="name" placeholder="Your name" required
              class="rounded-lg border border-line bg-ink/60 px-4 py-3 text-white placeholder-slate-400 focus:border-neon focus:outline-none focus:ring-1 focus:ring-neon" />
            <input type="email" name="email" placeholder="Email address" required
              class="rounded-lg border border-line bg-ink/60 px-4 py-3 text-white placeholder-slate-400 focus:border-neon focus:outline-none focus:ring-1 focus:ring-neon" />
            <select name="course" required
              class="rounded-lg border border-line bg-ink/60 px-4 py-3 text-white focus:border-neon focus:outline-none focus:ring-1 focus:ring-neon">
              <option value="" disabled selected>Interested in...</option>
              <option value="fundamentals">Fundamentals ($497)</option>
              <option value="advanced">Advanced ($997)</option>
              <option value="accelerator">Accelerator ($2,497)</option>
              <option value="bundle">All Courses Bundle ($2,997)</option>
              <option value="workshop">Team Workshop ($4,997)</option>
              <option value="not-sure">Not sure yet</option>
            </select>
            <button type="submit"
              class="rounded-lg bg-gradient-to-r from-violet to-neon px-6 py-3 font-semibold text-white transition hover:brightness-110">
              Join Waitlist →
            </button>
          </form>
          <p id="form-success" class="mt-4 hidden rounded-lg bg-green-900/40 border border-green-500/40 p-4 text-green-200">
            ✓ Thank you! We'll email you when enrollment opens.
          </p>
        </div>
      </section>

      <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
        <h2 class="font-display text-3xl sm:text-4xl">What Students Are Saying</h2>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          <blockquote class="rounded-2xl border border-line bg-panel/80 p-6">
            <p class="text-slate-200">"I went from what even is an agent to having one handle my inbox in a weekend."</p>
            <footer class="mt-4 text-sm text-slate-400">Marcus Chen, Startup Founder</footer>
          </blockquote>
          <blockquote class="rounded-2xl border border-line bg-panel/80 p-6">
            <p class="text-slate-200">"We trained our whole product team with the workshop. Now everyone can build automations without waiting on engineering."</p>
            <footer class="mt-4 text-sm text-slate-400">Sarah Kim, VP Product</footer>
          </blockquote>
          <blockquote class="rounded-2xl border border-line bg-panel/80 p-6">
            <p class="text-slate-200">"The agency accelerator paid for itself in my first client project."</p>
            <footer class="mt-4 text-sm text-slate-400">James O., AI Consultant</footer>
          </blockquote>
        </div>
      </section>

      <section id="faq" class="mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
        <h2 class="font-display text-3xl sm:text-4xl">FAQ</h2>
        <div class="mt-6 space-y-3" id="faq-list">
          <details class="group rounded-xl border border-line bg-panel/80 p-5" open>
            <summary class="cursor-pointer list-none font-semibold">How long do I have access?</summary>
            <p class="mt-3 text-slate-300">Lifetime access. Buy once and keep all future updates.</p>
          </details>
          <details class="group rounded-xl border border-line bg-panel/80 p-5">
            <summary class="cursor-pointer list-none font-semibold">Do I need to know how to code?</summary>
            <p class="mt-3 text-slate-300">No for Fundamentals. Advanced tracks include code, taught from scratch.</p>
          </details>
          <details class="group rounded-xl border border-line bg-panel/80 p-5">
            <summary class="cursor-pointer list-none font-semibold">What if I get stuck?</summary>
            <p class="mt-3 text-slate-300">Every course includes support plus private community access for questions.</p>
          </details>
          <details class="group rounded-xl border border-line bg-panel/80 p-5">
            <summary class="cursor-pointer list-none font-semibold">Can I expense this through my company?</summary>
            <p class="mt-3 text-slate-300">Yes. Invoices are provided and company details can be added.</p>
          </details>
          <details class="group rounded-xl border border-line bg-panel/80 p-5">
            <summary class="cursor-pointer list-none font-semibold">What's your refund policy?</summary>
            <p class="mt-3 text-slate-300">30-day money-back guarantee after completing the first two modules.</p>
          </details>
        </div>
      </section>
    </main>

    <footer class="border-t border-line/70 py-8">
      <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 text-sm text-slate-400 sm:px-6 lg:px-8">
        <p class="font-display tracking-[0.18em]">learn-openclaw.com</p>
        <p>Questions? courses@openclaw.io</p>
        <p>© 2026 OpenClaw. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const details = Array.from(document.querySelectorAll('#faq-list details'));
      details.forEach((item) => {
        item.addEventListener('toggle', () => {
          if (!item.open) return;
          details.forEach((other) => {
            if (other !== item) other.open = false;
          });
        });
      });
    </script>
    <script>
      document.getElementById('waitlist-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const data = {
          name: form.name.value,
          email: form.email.value,
          course: form.course.value,
          source: 'courses-page',
          timestamp: new Date().toISOString()
        };
        
        // Store locally as backup
        const stored = JSON.parse(localStorage.getItem('openclaw-waitlist') || '[]');
        stored.push(data);
        localStorage.setItem('openclaw-waitlist', JSON.stringify(stored));
        
        // Try to send to webhook (will work once n8n is configured)
        try {
          await fetch('https://n8n.openclaw.io/webhook/courses-waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
        } catch (err) {
          console.log('Webhook pending setup - stored locally');
        }
        
        // Show success
        form.classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      });
    </script>
  </body>
</html>
